# PrivatePulse AI - Backend Environment Variables

# LLM (Groq) - Required
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.2-90b-vision-preview

# Embedding Provider - "ollama" (local, no API key) or "openai" (cloud)
EMBEDDING_PROVIDER=ollama

# Ollama settings (used when EMBEDDING_PROVIDER=ollama)
# Make sure to run: ollama pull nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# OpenAI (only needed if EMBEDDING_PROVIDER=openai)
# Get your key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your-openai-api-key-here

# Database & Storage
DATABASE_URL=sqlite:///./privatepulse.db
UPLOAD_DIR=./uploads
CHROMA_PERSIST_DIR=./data/chroma_db

# Upload limits
MAX_UPLOAD_SIZE_MB=20
ALLOWED_EXTENSIONS=pdf,txt,docx

# RAG settings
TOP_K_RETRIEVAL=5
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# Server
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000